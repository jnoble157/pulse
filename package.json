{
  "name": "pulse",
  "version": "0.0.0",
  "private": true,
  "description": "A live restaurant voice agent demo.",
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "check": "turbo run typecheck lint test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@pulse/web",
    "dev:voice": "turbo run dev --filter=@pulse/voice",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "db:generate": "pnpm --filter @pulse/schema db:generate",
    "db:migrate": "pnpm --filter @pulse/schema db:migrate",
    "db:studio": "pnpm --filter @pulse/schema db:studio",
    "seed:voice": "pnpm --filter @pulse/schema seed:voice",
    "example-calls:build": "tsx scripts/example-calls.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
