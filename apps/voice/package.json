{
  "name": "@pulse/voice",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --build",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "build": "tsc --build",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "dev": "tsx watch --conditions=development --env-file=../../.env src/index.ts",
    "start": "node dist/index.js",
    "scenario:eval": "tsx --env-file=../../.env scripts/scenario-evals.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/node-ws": "^1.0.5",
    "@pulse/schema": "workspace:*",
    "@pulse/telemetry": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.13",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
