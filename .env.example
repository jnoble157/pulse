# Copy to .env and fill in values. Never commit `.env` — it is gitignored.

# --- Core (DB + migrations + voice boot) ---
ANTHROPIC_API_KEY=                              # https://console.anthropic.com
DATABASE_URL=postgresql://postgres:pulse@localhost:55432/pulse
PII_ENCRYPTION_KEY=                             # openssl rand -hex 32

# --- App config ---
NODE_ENV=development
LOG_LEVEL=info

# --- Web (apps/web) ---
DEMO_PASSWORD=
DEMO_COOKIE_SECRET=                             # openssl rand -hex 32
TWILIO_PHONE_NUMBER=+1...
LIVE_CALLS_PUSH_TOKEN=                          # openssl rand -hex 32; same in voice service

# --- Voice (apps/voice) ---
PUBLIC_BASE_URL=http://127.0.0.1:8788
WEB_BASE_URL=http://127.0.0.1:3000
PULSE_TENANT_SLUG=tonys-pizza-austin
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=

# --- Example audio (scripts/example-calls.ts) ---
OPENAI_API_KEY=                                 # gpt-4o-mini-tts for sample MP3s; omit if you only use checked-in audio

# --- Observability (optional) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=pulse
