# Copy to .env and fill in values. Never commit `.env` — it is gitignored.

# --- Core (DB + migrations + voice boot) ---
ANTHROPIC_API_KEY=                              # https://console.anthropic.com
# Local Docker: port 55432 matches infra/docker-compose.yml. On Railway use the Postgres service URL (Variables), not localhost.
DATABASE_URL=postgresql://postgres:pulse@localhost:55432/pulse
PII_ENCRYPTION_KEY=                             # openssl rand -hex 32

# --- App config ---
NODE_ENV=development
LOG_LEVEL=info

# --- Web (apps/web) ---
DEMO_PASSWORD=
DEMO_COOKIE_SECRET=                             # openssl rand -hex 32
TWILIO_PHONE_NUMBER=+1...
# Shared secret so only your voice service can POST transcript events to Next.
# Generate: openssl rand -hex 32
# - Set the SAME value on Railway (voice) and Vercel (web) for live transcripts.
# - If you omit it on BOTH: voice still answers calls; web push route accepts
#   unauthenticated POSTs (fine for local dev only — set a token before public deploy).
LIVE_CALLS_PUSH_TOKEN=

# --- Voice (apps/voice) ---
PUBLIC_BASE_URL=http://127.0.0.1:8788
WEB_BASE_URL=http://127.0.0.1:3000
PULSE_TENANT_SLUG=tonys-pizza-austin
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=iP95p4xoKVk53GoZ742B
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=

# --- Example audio (scripts/example-calls.ts) ---
EXAMPLE_AGENT_VOICE_ID=iP95p4xoKVk53GoZ742B
EXAMPLE_CALLER_ORDER_VOICE_ID=TX3LPaxmHKxFdv7VOQHJ
EXAMPLE_CALLER_ALLERGY_VOICE_ID=cgSgspJ2msm6clMCkdW9

# --- Observability (optional) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=pulse
